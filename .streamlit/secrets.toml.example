# Dashboard (Streamlit Cloud) secrets — read-only Supabase access only.
# Copy to .streamlit/secrets.toml for local dev, or paste into Streamlit Cloud → App settings → Secrets.
#
# Processor secrets (APIFY_API_TOKEN, OPENAI_API_KEY, SUPABASE_SERVICE_KEY)
# go in GitHub Actions → Settings → Secrets — NOT here.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your_anon_key_here"
